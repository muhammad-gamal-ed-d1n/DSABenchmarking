<configuration>

    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>benchmark.log</file>
        <append>true</append>

        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="FILE" />
    </root>

</configuration>